# =============================================================================
# FST Pay - Production Environment Variables
# Copy this file to .env, fill in real values, and NEVER commit .env
# =============================================================================

# --- REQUIRED: Database ---
POSTGRES_PASSWORD=changeme_secure_random_32_chars

# --- REQUIRED: JWT ---
# Generate with: openssl rand -base64 64
JWT_SECRET=

# --- REQUIRED: CORS ---
# Comma-separated list of allowed origins (no trailing slash)
CORS_ALLOWED_ORIGINS=https://fstpay.com,https://admin.fstpay.com

# --- OPTIONAL: Email (SMTP) ---
MAIL_USERNAME=
MAIL_PASSWORD=

# --- OPTIONAL: Admin seeding (first-run only) ---
ADMIN_EMAIL=admin@fstpay.com
ADMIN_PASSWORD=Admin@Secure123
ADMIN_FULLNAME=Administrator

# --- OPTIONAL: AI Coach ---
AI_PROVIDER=gemini
GEMINI_API_KEY=
# OPENAI_API_KEY=

# --- OPTIONAL: reCAPTCHA ---
RECAPTCHA_SECRET_KEY=

# --- OPTIONAL: Redis password ---
REDIS_PASSWORD=

# --- OPTIONAL: Log level (INFO, WARN, DEBUG) ---
LOG_LEVEL=INFO
